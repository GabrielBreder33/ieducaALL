APP_IMAGE=ghcr.io/seu-usuario/serviceieduca:latest
API_PORT=8080
ASPNETCORE_ENVIRONMENT=Production

# String completa para banco PostgreSQL externo (RDS, Cloud SQL, Supabase, etc.)
DB_CONNECTION_STRING=Host=seu-servidor;Port=5432;Database=serviceieduca;Username=seu_usuario;Password=sua_senha_forte;

DEEPSEEK_API_KEY=insira_sua_chave_aqui
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat
